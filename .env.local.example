# 환경 구분 (local / dev)
APP_ENV=local

# MCP 서버 이름
SERVER_NAME=auto-mcp-server

# Jira 서버 설정
JIRA_BASE_URL=http://your-jira-server:8080
USER_ID=your_jira_username
USER_PASSWORD=your_jira_password

# Confluence Wiki 설정 (이슈 정리 자동화)
# WIKI_BASE_URL: Confluence 베이스 URL (Jira와 같은 서버인 경우 JIRA_BASE_URL과 동일)
WIKI_BASE_URL=http://your-confluence-server:8090
# WIKI_ISSUE_SPACE_KEY: "이슈정리" 페이지가 속한 Confluence Space Key
WIKI_ISSUE_SPACE_KEY=YOUR_SPACE_KEY
# WIKI_ISSUE_ROOT_PAGE_ID: wiki 기본 루트 페이지의 Page ID
WIKI_ISSUE_ROOT_PAGE_ID=123456

# Wiki 작성자 이름 (Wiki 페이지 제목에 사용, 예: "[홍길동] 2026" → title_formats의 {{ AUTHOR_NAME }})
WIKI_AUTHOR_NAME=YourName

# Git 저장소 매핑 (JSON 형식)
# collect_branch_commits 도구에서 repository_path 미지정 시 여기 등록된 저장소에서 브랜치를 자동 탐지합니다
 GIT_REPOSITORIES='{"oper-back-office": "YOUR_BACKOFFICE_PATH", "supplier-back-office": "YOUR_BACKOFFICE_PATH", "gift-app": "/YOUR_PORTER_PATH"}'

# Diff 최대 문자수 (include_diff=true 시 스마트 필터링 후 반환할 최대 크기, 기본값: 30000)
 MAX_DIFF_CHARS=30000

# ============================================================
# 프로젝트별 Jira 설정 (필수)
# ============================================================
# 각 프로젝트 객체의 필수/선택 속성:
#   - key              (필수) Jira 프로젝트 키 (이슈키 프리픽스)
#   - due_date_field    (필수) 완료 시 종료일을 기록할 Jira 필드명. null이면 종료일 미설정
#   - wiki_date_field   (필수) Wiki 년/월 경로에 사용할 Jira 필드명. 빈 문자열이면 날짜 없음
#   - jira_custom_fields (선택) 커스텀 필드 표시명↔ID 매핑. 예: {"종료일": "customfield_12345"}
#                              Jira 조회 시 해당 필드를 추가 요청하고, 결과에 표시명으로 출력
#   - statuses          (선택) MCP Tool 안내에 표시할 주요 상태값 목록
#
# ※ 커스텀 필드 ID 확인 방법:
#   GET {JIRA_BASE_URL}/rest/api/2/field 호출 → 응답에서 name/id 매핑 확인
#   예: { "id": "customfield_12345", "name": "종료일", "custom": true }
# ============================================================
JIRA_PROJECT_CONFIGS='[
  {
    "key": "프로젝트A",
    "due_date_field": "customfield_12345",
    "wiki_date_field": "customfield_12345",
    "jira_custom_fields": {"완료예정일": "customfield_12345"},
    "statuses": ["할일", "진행중", "검수대기", "완료"]
  },
  {
    "key": "프로젝트B",
    "due_date_field": null,
    "wiki_date_field": "created",
    "jira_custom_fields": {},
    "statuses": ["접수", "처리중", "답변완료"]
  }
]'

